<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <graph edgedefault="directed">
    <node id="constructor" />
    <node id="withdraw" />
    <node id="getPuppetCount" />
    <node id="newPuppet" />
    <node id="setExtra" />
    <node id="fundPuppets" />
    <node id="mul" />
    <node id="div" />
    <node id="sub" />
    <node id="add" />
    <node id="require" />
    <node id="assert" />
    <edge source="constructor" target="newPuppet" />
    <edge source="withdraw" target="require" />
    <edge source="newPuppet" target="require" />
    <edge source="setExtra" target="require" />
    <edge source="fundPuppets" target="require" />
    <edge source="mul" target="assert" />
    <edge source="sub" target="assert" />
    <edge source="add" target="assert" />
  </graph>
</graphml>
