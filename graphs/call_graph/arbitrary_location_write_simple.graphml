<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <graph edgedefault="directed">
    <node id="constructor" />
    <node id="PushBonusCode" />
    <node id="PopBonusCode" />
    <node id="UpdateBonusCodeAt" />
    <node id="Destroy" />
    <node id="require" />
    <node id="selfdestruct" />
    <edge source="PopBonusCode" target="require" />
    <edge source="UpdateBonusCodeAt" target="require" />
    <edge source="Destroy" target="require" />
    <edge source="Destroy" target="selfdestruct" />
  </graph>
</graphml>
