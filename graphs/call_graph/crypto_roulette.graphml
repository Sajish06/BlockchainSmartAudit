<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <graph edgedefault="directed">
    <node id="CryptoRoulette" />
    <node id="shuffle" />
    <node id="play" />
    <node id="kill" />
    <node id="constructor" />
    <node id="sha3" />
    <node id="require" />
    <node id="suicide" />
    <edge source="CryptoRoulette" target="shuffle" />
    <edge source="shuffle" target="sha3" />
    <edge source="play" target="require" />
    <edge source="play" target="shuffle" />
    <edge source="kill" target="suicide" />
  </graph>
</graphml>
