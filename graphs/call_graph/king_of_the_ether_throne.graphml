<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <graph edgedefault="directed">
    <node id="KingOfTheEtherThrone" />
    <node id="numberOfMonarchs" />
    <node id="constructor" />
    <node id="claimThrone" />
    <node id="sweepCommission" />
    <node id="transferOwnership" />
    <node id="Monarch" />
    <node id="ThroneClaimed" />
    <edge source="KingOfTheEtherThrone" target="Monarch" />
    <edge source="constructor" target="claimThrone" />
    <edge source="claimThrone" target="Monarch" />
    <edge source="claimThrone" target="ThroneClaimed" />
  </graph>
</graphml>
