<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <graph edgedefault="directed">
    <node id="Government" />
    <node id="lendGovernmentMoney" />
    <node id="constructor" />
    <node id="totalDebt" />
    <node id="totalPayedOut" />
    <node id="investInTheSystem" />
    <node id="inheritToNextGeneration" />
    <node id="getCreditorAddresses" />
    <node id="getCreditorAmounts" />
    <edge source="constructor" target="lendGovernmentMoney" />
  </graph>
</graphml>
