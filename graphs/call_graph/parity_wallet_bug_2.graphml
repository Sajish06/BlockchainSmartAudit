    <edge source="confirm" target="MultiTransact" />
    <edge source="constructor" target="Deposit" />
    <edge source="initDaylimit" target="today" />
    <edge source="resetSpentToday" target="sha3" />
    <edge source="initWallet" target="initDaylimit" />
    <edge source="initWallet" target="initMultiowned" />
    <edge source="kill" target="suicide" />
    <edge source="kill" target="sha3" />
    <edge source="confirmAndCheck" target="Confirmation" />
    <edge source="underLimit" target="today" />
  </graph>
</graphml>
