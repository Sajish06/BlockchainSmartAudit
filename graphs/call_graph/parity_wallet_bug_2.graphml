    <node id="confirm" />
    <node id="constructor" />
    <node id="initMultiowned" />
    <node id="getOwner" />
    <node id="initDaylimit" />
    <node id="resetSpentToday" />
    <node id="initWallet" />
    <node id="kill" />
    <node id="create" />
    <node id="confirmAndCheck" />
    <node id="reorganizeOwners" />
    <node id="underLimit" />
    <node id="today" />
    <node id="clearPending" />
    <node id="Deposit" />
    <node id="Revoke" />
    <node id="OwnerChanged" />
    <node id="sha3" />
    <node id="OwnerAdded" />
    <node id="OwnerRemoved" />
    <node id="RequirementChanged" />
    <node id="suicide" />
    <node id="ConfirmationNeeded" />
    <node id="SingleTransact" />
    <node id="MultiTransact" />
    <node id="Confirmation" />
    <edge source="revoke" target="Revoke" />
    <edge source="changeOwner" target="isOwner" />
    <edge source="changeOwner" target="clearPending" />
    <edge source="changeOwner" target="OwnerChanged" />
    <edge source="changeOwner" target="sha3" />
    <edge source="addOwner" target="isOwner" />
    <edge source="addOwner" target="clearPending" />
    <edge source="addOwner" target="reorganizeOwners" />
    <edge source="addOwner" target="OwnerAdded" />
    <edge source="addOwner" target="sha3" />
    <edge source="removeOwner" target="clearPending" />
    <edge source="removeOwner" target="reorganizeOwners" />
    <edge source="removeOwner" target="OwnerRemoved" />
    <edge source="removeOwner" target="sha3" />
    <edge source="changeRequirement" target="clearPending" />
    <edge source="changeRequirement" target="RequirementChanged" />
    <edge source="changeRequirement" target="sha3" />
    <edge source="setDailyLimit" target="sha3" />
    <edge source="execute" target="underLimit" />
    <edge source="execute" target="sha3" />
    <edge source="execute" target="confirm" />
