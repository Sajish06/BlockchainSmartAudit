<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <graph edgedefault="directed">
    <node id="withdrawReward" />
    <node id="getFirstWithdrawalBonus" />
    <node id="require" />
    <edge source="withdrawReward" target="require" />
    <edge source="getFirstWithdrawalBonus" target="require" />
    <edge source="getFirstWithdrawalBonus" target="withdrawReward" />
  </graph>
</graphml>
